{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "explore": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "max"
    },
    "compaction": {
      "model": "openai/gpt-5.5",
      "variant": "low"
    }
  },
  "plugin": [
    "oc-arkive@latest",
    "opencode-gpt-imagegen"
  ],
  "compaction": {
    "auto": false,
    "prune": false
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": false
    }
  }
}
