{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "explore": {
      "model": "opencode-go/kimi-k2.6"
    },
    "simplicity-reviewer": {
      "model": "openai/gpt-5.3-codex",
      "variant": "xhigh"
    }
  },
  "plugin": [
    "oc-arkive@latest"
  ],
  "compaction": {
    "auto": false,
    "prune": false
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": false
    }
  }
}
