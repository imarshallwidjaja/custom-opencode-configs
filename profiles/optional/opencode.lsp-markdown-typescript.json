{
  "lsp": {
    "typescript": {
      "disabled": true
    },
    "marksman": {
      "command": [
        "marksman",
        "server"
      ],
      "extensions": [
        ".md",
        ".markdown"
      ]
    },
    "vtsls": {
      "command": [
        "vtsls",
        "--stdio"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx",
        ".mjs",
        ".cjs",
        ".mts",
        ".cts"
      ]
    }
  }
}
